  "qqq-function-confirm": {
    "prefix": "qqq-function-confirm",
    "body": [
      "function confirm(content: string, title = '温馨提示') {",
      "  return new Promise((resolve, reject) => {",
      "    Modal.confirm({",
      "      content,",
      "      title,",
      "      onOk() {",
      "        resolve(true);",
      "      },",
      "      onCancel() {",
      "        reject(new Error('用户取消操作'));",
      "      },",
      "    });",
      "  });",
      "}",
    ],
    "description": "Vben Admin 封装确认框 Promise 函数",
  },
  "qqq-function-status-change": {
    "prefix": "qqq-function-status-change",
    "body": [
      "async function onStatusChange(newStatus, row) {",
      "  await confirm(`你要将${row.name}的状态切换为 【${newStatus === 1 ? '启用' : '禁用'}】 吗？`, '状态切换')",
      "  await new Promise(resolve => setTimeout(resolve, 2000))",
      "  return true",
      "}",
    ],
    "description": "Vben Admin 封装状态切换函数",
  },
  "qqq-function-toggle-expand-all": {
    "prefix": "qqq-function-toggle-expand-all",
    "body": [
      "function toggleExpandAll() {",
      "  let isExpand = gridApi.grid?.getTreeExpandRecords()",
      "  message.info(`当前展开状态: ${!!isExpand.length ? '已展开' : '已收起'}`)",
      "  gridApi.grid?.setAllTreeExpand(!isExpand.length)",
      "}",
    ],
    "description": "Vben Admin 封装树形表格全部展开/收起功能",
  },
  "qqq-function-sleep": {
    "prefix": "qqq-function-sleep",
    "scope": "javascript,typescript,vue",
