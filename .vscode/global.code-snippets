  "qqq-page-template-index": {
    "prefix": "qqq-page-template-index",
    "scope": "vue",
    "body": [
      "<script setup>",
      "  import { Page, useVbenModal } from '@vben/common-ui'",
      "  import { Button } from 'ant-design-vue'",
      "  import dayjs from 'dayjs'",
      "",
      "  import { gridApiColumns, formApiSchema, gridApiSchema } from './data'",
      "",
      "  const [FormModal, formModalApi] = useVbenModal({",
      "    ...DEFAULT_MODAL_OPTIONS,",
      "    onConfirm: handleSubmit,",
      "  })",
      "",
      "  const [Form, formApi] = useVbenForm({",
      "    ...DEFAULT_MODAL_FORM_OPTIONS,",
      "    schema: formApiSchema(),",
      "  })",
      "",
      "  const [Grid, gridApi] = useVbenVxeGrid({",
      "    formOptions: {",
      "      ...DEFAULT_GRID_FORM_OPTIONS,",
      "      schema: gridApiSchema(),",
      "    },",
      "    gridOptions: {",
      "      ...DEFAULT_GRID_OPTIONS,",
      "      stripe: false,",
      "      columns: gridApiColumns(onActionClick),",
      "      proxyConfig: {",
      "        ajax: {",
      "          query: fetchTableData,",
      "        },",
      "      },",
      "    },",
      "  })",
      "",
      "  function onActionClick({ code, row }) {",
      "    switch (code) {",
      "      case 'append': {",
      "        addForm(row)",
      "        break",
      "      }",
      "      case 'edit': {",
      "        editRow(row)",
      "        break",
      "      }",
      "      case 'delete': {",
      "        deleteRow(row)",
      "        break",
      "      }",
      "    }",
      "  }",
      "",
      "  async function fetchTableData(page, formValues) {",
      "    console.log('搜索参数:', { page, formValues })",
      "",
      "    const mockData = Array.from({ length: 8 }, (_, i) => ({",
      "      id: i + 1,",
      "      remark: `这是第${i + 1}个部门`,",
      "    }))",
      "",
      "    return {",
      "      total: 100,",
      "      items: mockData,",
      "    }",
      "  }",
      "",
      "  async function handleSubmit() {",
      "    const { valid } = await formApi.validate()",
      "    if (!valid) return",
      "",
      "    const data = await formApi.getValues()",
      "    console.log('🚀 ~ handleSubmit ~ data:', data)",
      "",
      "    const isEdit = !!data.id",
      "",
      "    formModalApi.lock()",
      "    await new Promise(resolve => setTimeout(resolve, 2000))",
      "",
      "    try {",
      "      message.success(isEdit ? '编辑成功' : '添加成功')",
      "      formModalApi.close()",
      "      gridApi.query()",
      "    } finally {",
      "      formModalApi.lock(false)",
      "    }",
      "  }",
      "",
      "  function deleteRow(row) {",
      "    const hideLoading = message.loading({",
      "      content: `正在删除中...`,",
      "      duration: 0,",
      "      key: 'action_process_msg',",
      "    })",
      "    setTimeout(() => {",
      "      message.success({",
      "        content: `删除成功`,",
      "        key: 'action_process_msg',",
      "      })",
      "      gridApi.query()",
      "    }, 2000)",
      "  }",
      "",
      "  function editRow(row) {",
      "    formApi.setValues(row)",
      "    formModalApi",
      "      .setState({",
      "        title: '编辑部门',",
      "      })",
      "      .open()",
      "  }",
      "",
      "  function addForm(row) {",
      "    formModalApi",
      "      .setState({",
      "        title: '添加部门',",
      "      })",
      "      .setData(row)",
      "      .open()",
      "  }",
      "</script>",
      "",
      "<template>",
      "  <Page auto-content-height title=\"\" description=\"\">",
      "    <Grid table-title=\"\" table-title-help=\"\">",
      "      <template #table-title></template>",
      "      <template #toolbar-actions>",
      "        <div class=\"flex gap-3\" @click=\"addForm\">",
      "          <Button type=\"primary\">添加部门</Button>",
      "        </div>",
      "      </template>",
      "      <template #toolbar-tools>",
      "        <div class=\"flex gap-3 items-center\">",
      "        </div>",
      "      </template>",
      "    </Grid>",
      "    <FormModal>",
      "      <Form></Form>",
      "    </FormModal>",
      "  </Page>",
      "</template>",
    ],
    "description": "Vben Admin 树形表格完整CRUD页面",
