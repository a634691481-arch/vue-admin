      "      width: 50,",
      "      fixed: 'left',",
      "    },",
      "    {",
      "      field: 'remark',",
      "      title: '备注',",
      "    },",
      "    {",
      "      align: 'right',",
      "      cellRender: {",
      "        attrs: {",
      "          nameField: 'deptName',",
      "          nameTitle: '部门',",
      "          onClick: onActionClick,",
      "        },",
      "        name: 'CellOperation',",
      "        options: [",
      "          {",
      "            code: 'append',",
      "            text: '新增下级',",
      "          },",
      "          'edit',",
      "          {",
      "            code: 'delete',",
      "            disabled: (row: any) => {",
      "              return !!(row.children && row.children.length > 0)",
      "            },",
      "          },",
      "        ],",
      "      },",
      "      field: 'operation',",
      "      fixed: 'right',",
      "      headerAlign: 'center',",
      "      showOverflow: false,",
      "      title: '操作',",
      "      width: 200,",
      "    },",
      "  ]",
      "}",
      "",
      "/**",
      " * 获取搜索表单的字段配置",
      " */",
      "export function gridApiSchema() {",
      "  return [",
      "    {",
      "      component: 'Input',",
      "      fieldName: 'remark',",
      "      label: '备注',",
      "      componentProps: {",
      "        placeholder: '请输入备注',",
      "      },",
      "    },",
      "  ]",
      "}",
    ],
    "description": "Vben Admin 部门树形表格 表单+表格+搜索配置",
