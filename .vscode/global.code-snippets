  "qqq-function-open-prompt": {
    "prefix": "qqq-function-open-prompt",
    "body": [
      "async function openPrompt() {",
      "  prompt<string>({",
      "    async beforeClose({ isConfirm, value }) {",
      "      if (isConfirm && value === '${1:校验值}') {",
      "        message.error('${2:错误提示}')",
      "        return false",
      "      }",
      "    },",
      "    componentProps: { placeholder: '${3:请输入...}' },",
      "    content: '${4:提示内容}',",
      "    icon: 'question',",
      "    overlayBlur: ${5:3},",
      "  })",
      "    .then(res => {",
      "      message.success(`用户输入了：${res}`)",
      "    })",
      "    .catch(() => {",
      "      message.error('用户取消了输入')",
      "    })",
      "}",
    ],
    "description": "Vben Admin 封装 Prompt 输入弹窗函数（带校验）",
  },

